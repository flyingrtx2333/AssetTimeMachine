    },
    "用 1 分钟快速了解五个主要页面，之后也可以在设置里重新查看。": {
      "localizations": {
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "用 1 分钟快速了解五个主要页面，之后也可以在设置里重新查看。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "用 1 分鐘快速了解五個主要頁面，之後也可以在設定裡重新查看。"
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Take one minute to learn the app's five main pages. You can reopen this guide from Settings anytime."
          }
        }
      }
    },
