    "开始使用": {
      "localizations": {
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "开始使用"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "開始使用"
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Start"
          }
        }
      }
    },
    "在这里录入或修改当日资产、负债和价格，也可以查看全部历史记录。": {
      "localizations": {
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "在这里录入或修改当日资产、负债和价格，也可以查看全部历史记录。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "在這裡錄入或修改當日資產、負債和價格，也可以查看全部歷史記錄。"
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Record or edit today's assets, liabilities, and prices here, and review your full history."
          }
        }
      }
    },
    "操作建议": {
      "localizations": {
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "操作建议"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "操作建議"
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "How to use it"
          }
        }
      }
    },
    "把资产历史和黄金、纳指等锚点放在一起看，观察长期变化与折算结果。": {
      "localizations": {
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "把资产历史和黄金、纳指等锚点放在一起看，观察长期变化与折算结果。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "把資產歷史和黃金、納指等錨點放在一起看，觀察長期變化與折算結果。"
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Compare your asset history with anchors like gold and the Nasdaq to see long-term changes and equivalents."
          }
        }
      }
    },
    "模拟配置回测或定投回测，调整区间、权重和频率后查看策略表现。": {
      "localizations": {
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "模拟配置回测或定投回测，调整区间、权重和频率后查看策略表现。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "模擬配置回測或定投回測，調整區間、權重和頻率後查看策略表現。"
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Run allocation or DCA backtests, then tune ranges, weights, and frequency to evaluate performance."
          }
        }
      }
    },
    "欢迎使用资产时光机": {
      "localizations": {
        "zh-Hans": {
