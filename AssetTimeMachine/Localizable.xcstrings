    "按当前月均净资产增长 %@ 估算，在通胀率维持 %@ 的条件下，月开销需控制在 %@ 以内。": {
      "localizations": {
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "按当前月均净资产增长 %@ 估算，在通胀率维持 %@ 的条件下，月开销需控制在 %@ 以内。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "按當前月均淨資產增長 %@ 估算，在通脹率維持 %@ 的條件下，每月開銷需控制在 %@ 以內。"
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Based on the current average monthly net asset growth of %@, with inflation staying at %@, monthly spending should stay within %@."
          }
        }
      }
    },
    "按当前趋势估算，在通胀率维持 %@ 的条件下，即使将月开销降至 0，也无法达到目标线。": {
      "localizations": {
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "按当前趋势估算，在通胀率维持 %@ 的条件下，即使将月开销降至 0，也无法达到目标线。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "按當前趨勢估算，在通脹率維持 %@ 的條件下，即使將每月開銷降至 0，也無法達到目標線。"
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Based on the current trend, even reducing monthly spending to 0 will not reach the target if inflation remains at %@."
          }
        }
      }
    },
